<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Farzi Cafe</title>

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Poppins', sans-serif;
}

body {
    background: #0f0f0f;
    color: #fff;
}

/* HERO SECTION */
.hero {
    height: 90vh;
    background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.8)),
                url('https://images.unsplash.com/photo-1555396273-367ea4eb4db5');
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
}

.hero h1 {
    font-size: 60px;
    letter-spacing: 2px;
}

.hero p {
    margin-top: 10px;
    color: #ccc;
}

/* INFO BAR */
.info {
    background: #1a1a1a;
    padding: 15px;
    text-align: center;
    font-size: 14px;
    color: #f1c40f;
}

/* MENU SECTION */
.menu {
    padding: 50px 10%;
}

.menu h2 {
    text-align: center;
    margin-bottom: 30px;
    font-size: 32px;
    border-bottom: 2px solid #f1c40f;
    display: inline-block;
}

/* GRID */
.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 25px;
}

/* CARD */
.card {
    background: #1c1c1c;
    padding: 20px;
    border-radius: 15px;
    transition: 0.3s;
    border: 1px solid #333;
}

.card:hover {
    transform: translateY(-10px);
    border-color: #f1c40f;
}

.card h3 {
    margin-bottom: 10px;
}

.card p {
    font-size: 14px;
    color: #aaa;
}

.price {
    margin-top: 10px;
    color: #f1c40f;
    font-weight: bold;
}

/* CONTACT */
.contact {
    text-align: center;
    padding: 40px;
    background: #111;
}

/* FOOTER */
footer {
    text-align: center;
    padding: 15px;
    background: black;
    font-size: 14px;
    color: #777;
}
</style>

</head>

<body>

<!-- HERO -->
<section class="hero">
    <div>
        <h1>Farzi Cafe</h1>
        <p>Fine Dining Experience in Nagpur</p>
    </div>
</section>

<!-- INFO -->
<div class="info">
    ⭐ 4.1 Rating | 📍 Shivaji Nagar, Dharampeth, Nagpur |   
</div>

<!-- MENU -->
<section class="menu">
    <h2>Our Signature Menu</h2>

    <div class="grid">

        <div class="card">
            <h3>Paneer Tikka</h3>
            <p>Smoky grilled paneer with Indian spices</p>
            <div class="price">₹350</div>
        </div>

        <div class="card">
            <h3>Chicken Biryani</h3>
            <p>Flavorful basmati rice with tender chicken</p>
            <div class="price">₹450</div>
        </div>

        <div class="card">
            <h3>Margherita Pizza</h3>
            <p>Classic Italian delight with fresh cheese</p>
            <div class="price">₹300</div>
        </div>

        <div class="card">
            <h3>White Sauce Pasta</h3>
            <p>Creamy Alfredo pasta with herbs</p>
            <div class="price">₹400</div>
        </div>

        <div class="card">
            <h3>Chocolate Brownie</h3>
            <p>Served hot with vanilla ice cream</p>
            <div class="price">₹250</div>
        </div>

        <div class="card">
            <h3>Mojito</h3>
            <p>Refreshing mint lime cooler</p>
            <div class="price">₹180</div>
        </div>

    </div>
</section>

<!-- CONTACT -->
<section class="contact">
    <h2>Contact Us</h2>
    <p>📞 +91 8600777666</p>
    <p>💰 ₹3,000 for two</p>
</section>

<!-- FOOTER -->
<footer>
    © 2026 Farzi Cafe | All Rights Reserved
</footer>

</body>
</html>
